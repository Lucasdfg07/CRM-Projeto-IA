<% content_for :page_title, "Painel operacional" %>

<div class="grid gap-6 lg:grid-cols-12">
  <section class="crm-glass p-6 lg:col-span-8">
    <h2 class="mb-4 font-display text-lg text-cyan-100">Resumo orbital</h2>
    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
      <% [
        ["Empresas", @counts[:companies], "Cadastros ativos"],
        ["Contatos", @counts[:contacts], "Relacionamentos"],
        ["Pipeline", @counts[:deals_open], "Negócios em aberto"],
        ["Atividade (7d)", @counts[:activities_week], "Interações registradas"]
      ].each do |title, value, hint| %>
        <div class="crm-glass-subtle p-4">
          <p class="crm-label"><%= title %></p>
          <p class="mt-2 font-display text-3xl text-white"><%= value %></p>
          <p class="mt-1 text-xs text-slate-500"><%= hint %></p>
        </div>
      <% end %>
    </div>
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      <div class="crm-glass-subtle p-4">
        <h3 class="text-sm font-semibold text-violet-200">Funil por etapa</h3>
        <ul class="mt-3 space-y-2 text-sm text-slate-300">
          <% @pipeline.each do |stage, count| %>
            <li class="flex justify-between border-b border-white/5 pb-2">
              <span class="capitalize"><%= stage %></span>
              <span class="crm-badge"><%= count %></span>
            </li>
          <% end %>
          <% if @pipeline.empty? %>
            <li class="text-slate-500">Nenhum negócio em pipeline — crie o primeiro.</li>
          <% end %>
        </ul>
      </div>
      <div class="crm-glass-subtle p-4">
        <h3 class="text-sm font-semibold text-cyan-200">Automação N8N</h3>
        <p class="mt-2 text-sm leading-relaxed text-slate-400">
          Eventos de empresas, contatos, negócios e atividades disparam <code class="text-cyan-200/90">POST</code>
          para <code class="text-cyan-200/90">N8N_WEBHOOK_URL</code> com assinatura opcional.
        </p>
        <p class="mt-4 text-xs text-slate-500">
          Consuma <code class="text-cyan-200/80">GET /api/v1/…</code> com header <code class="text-cyan-200/80">Authorization: Bearer</code> configurado em <code class="text-cyan-200/80">CRM_API_TOKEN</code>.
        </p>
      </div>
    </div>
  </section>
  <section class="crm-glass p-6 lg:col-span-4">
    <h2 class="mb-4 font-display text-lg text-cyan-100">Linha do tempo</h2>
    <ul class="space-y-4">
      <% @recent_activities.each do |a| %>
        <li class="crm-glass-subtle p-3">
          <p class="text-xs uppercase tracking-wide text-violet-300/80"><%= a.kind %> · <%= l a.occurred_at, format: :short %></p>
          <p class="mt-1 font-medium text-slate-100"><%= a.subject %></p>
          <p class="text-xs text-slate-500"><%= a.contact&.full_name %> <%= "· #{a.deal.name}" if a.deal %></p>
        </li>
      <% end %>
      <% if @recent_activities.empty? %>
        <li class="text-sm text-slate-500">Sem atividades recentes.</li>
      <% end %>
    </ul>
    <%= link_to "Nova atividade", new_activity_path, class: "crm-btn-primary mt-6 w-full" %>
  </section>
</div>
