<% content_for :page_title, "Atividades" %>

<div class="mb-6 flex flex-wrap items-center justify-between gap-3">
  <%= link_to "Registrar atividade", new_activity_path, class: "crm-btn-primary" %>
</div>

<div class="crm-glass divide-y divide-white/5 p-0">
  <% @activities.each do |a| %>
    <div class="flex flex-wrap items-start justify-between gap-4 px-6 py-4">
      <div>
        <p class="text-xs uppercase tracking-wide text-violet-300/90"><%= activity_kind_label(a.kind) %> · <%= l a.occurred_at, format: :short %></p>
        <p class="mt-1 text-lg font-medium text-white"><%= link_to a.subject, a %></p>
        <% if a.body.present? %>
          <p class="mt-2 max-w-2xl text-sm text-slate-400"><%= truncate(a.body, length: 240) %></p>
        <% end %>
        <p class="mt-2 text-xs text-slate-500">
          <%= a.contact&.full_name %>
          <%= " · #{a.deal.name}" if a.deal %>
        </p>
      </div>
      <%= link_to "Abrir", a, class: "crm-btn-ghost text-xs" %>
    </div>
  <% end %>
  <% if @activities.empty? %>
    <p class="p-6 text-sm text-slate-500">Nenhuma atividade.</p>
  <% end %>
</div>
