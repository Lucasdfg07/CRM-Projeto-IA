<%= form_with model: [@company, @contact], class: "space-y-4" do |f| %>
  <%= render "shared/errors", record: @contact %>
  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <%= f.label :first_name, class: "crm-label" %>
      <%= f.text_field :first_name, class: "crm-input" %>
    </div>
    <div>
      <%= f.label :last_name, class: "crm-label" %>
      <%= f.text_field :last_name, class: "crm-input" %>
    </div>
    <div>
      <%= f.label :email, class: "crm-label" %>
      <%= f.email_field :email, class: "crm-input" %>
    </div>
    <div>
      <%= f.label :phone, class: "crm-label" %>
      <%= f.text_field :phone, class: "crm-input" %>
    </div>
    <div>
      <%= f.label :title, class: "crm-label" %>
      <%= f.text_field :title, class: "crm-input", placeholder: "Cargo" %>
    </div>
    <div>
      <%= f.label :lifecycle_stage, class: "crm-label" %>
      <%= f.select :lifecycle_stage, Contact::LIFECYCLES.map { |s| [lifecycle_label(s), s] }, {}, class: "crm-input" %>
    </div>
  </div>
  <div class="flex flex-wrap gap-3">
    <%= f.submit class: "crm-btn-primary" %>
    <%= link_to "Cancelar", company_path(@company), class: "crm-btn-ghost" %>
  </div>
<% end %>
