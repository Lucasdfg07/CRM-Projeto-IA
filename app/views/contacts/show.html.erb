<% content_for :page_title, @contact.full_name %>

<div class="mb-6 flex flex-wrap items-center justify-between gap-3">
  <div>
    <p class="text-sm text-slate-400"><%= link_to @company.name, @company %> · <span><%= lifecycle_label(@contact.lifecycle_stage) %></span></p>
    <p class="text-sm text-slate-300"><%= @contact.email %> · <%= @contact.phone %></p>
  </div>
  <div class="flex flex-wrap gap-2">
    <%= link_to "Nova atividade", new_activity_path(contact_id: @contact.id), class: "crm-btn-primary" %>
    <%= link_to "Editar", edit_company_contact_path(@company, @contact), class: "crm-btn-ghost" %>
    <%= button_to "Excluir", company_contact_path(@company, @contact), method: :delete, form: { data: { turbo_confirm: "Remover contato?" } }, class: "crm-btn-ghost border-rose-400/35 text-rose-100" %>
  </div>
</div>

<div class="crm-glass p-6">
  <h2 class="font-display text-lg text-cyan-100">Atividades recentes</h2>
  <% recent = @contact.activities.order(occurred_at: :desc).limit(10) %>
  <ul class="mt-4 space-y-3">
    <% recent.each do |a| %>
      <li class="crm-glass-subtle p-3">
        <p class="text-xs uppercase tracking-wide text-violet-300/80"><%= activity_kind_label(a.kind) %> · <%= l a.occurred_at, format: :short %></p>
        <p class="font-medium text-white"><%= link_to a.subject, a %></p>
      </li>
    <% end %>
    <% if recent.empty? %>
      <li class="text-sm text-slate-500">Nada registrado ainda.</li>
    <% end %>
  </ul>
</div>
