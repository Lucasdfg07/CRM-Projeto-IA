<% segments = Segment.order(:name) %>

<%= form_with model: form, class: "space-y-0", data: { controller: "form-builder" } do |f| %>
  <%= render "shared/errors", object: form %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Left: settings -->
    <div class="space-y-5">
      <div class="bg-slate-900/70 border border-white/10 rounded-2xl p-5 space-y-4 backdrop-blur-xl">
        <h2 class="font-semibold text-white text-sm uppercase tracking-wider">Configurações</h2>

        <div>
          <%= f.label :name, "Nome do formulário", class: "block text-xs font-medium text-slate-400 mb-1" %>
          <%= f.text_field :name, placeholder: "Ex: Lead Magnético — Natal 2026", class: "w-full bg-slate-950 border border-slate-700 rounded-lg px-3 py-2 text-white text-sm placeholder-slate-600 focus:outline-none focus:ring-2 focus:ring-cyan-400" %>
          <p class="text-xs text-slate-600 mt-1">Este é o nome do formulário (não confundir com o rótulo das perguntas).</p>
        </div>

        <div>
          <%= f.label :description, "Descrição (opcional)", class: "block text-xs font-medium text-slate-400 mb-1" %>
          <%= f.text_area :description, rows: 2, placeholder: "Uma frase curta para contexto…", class: "w-full bg-slate-950 border border-slate-700 rounded-lg px-3 py-2 text-white text-sm placeholder-slate-600 focus:outline-none focus:ring-2 focus:ring-cyan-400" %>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.label :accent_color, "Cor de destaque", class: "block text-xs font-medium text-slate-400 mb-1" %>
            <div class="flex items-center gap-3">
              <%= f.color_field :accent_color, class: "w-12 h-10 rounded-lg border border-slate-700 bg-slate-950 cursor-pointer p-1" %>
              <span class="text-xs text-slate-500">Neo-cyan</span>
            </div>
          </div>
          <div>
            <%= f.label :slug, "Slug público", class: "block text-xs font-medium text-slate-400 mb-1" %>
            <%= f.text_field :slug, placeholder: "auto-gerado", class: "w-full bg-slate-950 border border-slate-700 rounded-lg px-3 py-2 text-white text-sm placeholder-slate-600 focus:outline-none focus:ring-2 focus:ring-cyan-400" %>
          </div>
        </div>

        <div>
          <%= f.label :target_segment_id, "Segmento alvo", class: "block text-xs font-medium text-slate-400 mb-1" %>
          <%= f.select :target_segment_id,
                segments.map { |s| ["#{s.name} (#{s.contacts_count})", s.id] },
                { include_blank: "Nenhum (não segmentar automaticamente)" },
                class: "w-full bg-slate-950 border border-slate-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:ring-2 focus:ring-cyan-400" %>
          <p class="text-xs text-slate-600 mt-1">Ao responder, o lead será adicionado a este segmento.</p>
        </div>

        <div class="flex items-center justify-between">
          <label class="flex items-center gap-2 cursor-pointer">
            <%= f.check_box :enabled, class: "w-4 h-4 rounded accent-cyan-400" %>
            <span class="text-sm text-slate-300">Formulário ativo</span>
          </label>
          <% if form.persisted? %>
            <%= link_to "Abrir link público", public_form_path(form.slug), target: "_blank", class: "text-xs text-cyan-300 hover:text-cyan-200" %>
          <% end %>
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <%= f.submit form.persisted? ? "Salvar alterações" : "Criar formulário", class: "w-full bg-cyan-400 hover:bg-cyan-300 text-slate-950 text-sm font-semibold py-2.5 rounded-lg cursor-pointer transition" %>
        <%= link_to "Cancelar", forms_path, class: "block w-full text-center bg-slate-800 hover:bg-slate-700 text-slate-200 text-sm py-2.5 rounded-lg transition" %>
      </div>
    </div>

    <!-- Right: builder -->
    <div class="lg:col-span-2 space-y-4">
      <div class="bg-slate-900/70 border border-white/10 rounded-2xl p-4 backdrop-blur-xl flex flex-wrap gap-2 items-center">
        <button type="button"
                data-action="click->form-builder#openPalette"
                class="text-xs bg-white text-slate-950 hover:bg-slate-100 px-4 py-2 rounded-lg font-semibold transition">
          Adicionar elementos
        </button>
        <div class="ml-auto text-xs text-slate-500">
          Dica: inclua <span class="text-slate-300">E-mail</span> para criar o contato automaticamente.
        </div>
      </div>

      <div class="bg-slate-950/60 border border-white/10 rounded-2xl p-4 backdrop-blur-xl">
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-semibold text-white text-sm uppercase tracking-wider">Campos do formulário</h2>
          <span class="text-xs text-slate-500">Arraste/ordene na próxima iteração</span>
        </div>

        <div class="space-y-3" data-form-builder-target="fields">
          <%= f.fields_for :form_fields do |ff| %>
            <%= render "field", f: ff %>
          <% end %>
        </div>

        <template data-form-builder-target="template">
          <%= f.fields_for :form_fields, FormField.new, child_index: "NEW_RECORD" do |ff| %>
            <%= render "field", f: ff %>
          <% end %>
        </template>
      </div>

      <div class="bg-indigo-500/10 border border-indigo-500/20 rounded-xl px-4 py-3 text-xs text-indigo-200">
        <strong>Segmentação automática:</strong> se o formulário tiver “Segmento alvo”, o lead será adicionado nesse segmento e poderá ser usado em campanhas em <code class="bg-indigo-500/20 px-1 rounded">Campanhas</code>.
      </div>
    </div>
  </div>

  <!-- Palette modal (Typeform-like) -->
  <div class="hidden fixed inset-0 z-50 items-center justify-center bg-black/60 backdrop-blur-sm"
       data-form-builder-target="modal"
       data-action="click->form-builder#closePalette">
    <div class="w-full max-w-4xl bg-white rounded-2xl shadow-2xl border border-black/10 overflow-hidden"
         data-action="click->form-builder#noop">
    <div class="flex items-center gap-3 px-5 py-4 border-b border-slate-200">
      <div class="flex gap-2">
        <button type="button" class="text-sm font-semibold text-slate-900 border border-slate-200 rounded-full px-4 py-2">Adicionar elementos</button>
        <button type="button" class="text-sm text-slate-500 border border-slate-200 rounded-full px-4 py-2 opacity-60 cursor-not-allowed" disabled>Importar perguntas</button>
        <button type="button" class="text-sm text-slate-500 border border-slate-200 rounded-full px-4 py-2 opacity-60 cursor-not-allowed" disabled>Criar com IA</button>
      </div>
      <button type="button" class="ml-auto w-9 h-9 rounded-full hover:bg-slate-100 text-slate-500"
              data-action="click->form-builder#closePalette">✕</button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 min-h-[520px]">
      <!-- left column -->
      <div class="md:col-span-1 border-r border-slate-200 p-4">
        <div class="relative">
          <input type="text"
                 data-form-builder-target="search"
                 data-action="input->form-builder#filterPalette"
                 placeholder="Buscar elementos"
                 class="w-full rounded-xl border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-cyan-300">
        </div>

        <div class="mt-5">
          <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Recomendados</p>
          <button type="button"
                  data-form-builder-target="paletteItem"
                  data-search-text="Tela de boas-vindas"
                  data-action="click->form-builder#addFromPalette"
                  data-field-type="text"
                  data-field-label="Bem-vindo!"
                  data-field-placeholder="Digite para continuar..."
                  class="w-full text-left rounded-xl border border-slate-200 p-3 hover:bg-slate-50 transition">
            <p class="text-sm font-semibold text-slate-900">Tela de boas-vindas</p>
            <p class="text-xs text-slate-500 mt-1">Introdução do formulário</p>
          </button>
        </div>

        <div class="mt-6">
          <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Conectar a apps</p>
          <div class="rounded-xl border border-dashed border-slate-200 p-3 text-xs text-slate-400">
            Integrações desabilitadas neste CRM.
          </div>
        </div>
      </div>

      <!-- main palette -->
      <div class="md:col-span-3 p-5 space-y-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-3">Informações de contato</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <button type="button"
                      data-form-builder-target="paletteItem"
                      data-search-text="Contato Nome"
                      data-action="click->form-builder#addFromPalette"
                      data-field-type="text"
                      data-field-label="Qual o seu nome?"
                      data-field-required="true"
                      data-field-placeholder="Digite sua resposta aqui..."
                      class="rounded-xl border border-slate-200 p-3 hover:bg-slate-50 text-left transition">
                <p class="text-sm font-semibold text-slate-900">Contato</p>
                <p class="text-xs text-slate-500 mt-1">Nome</p>
              </button>
              <button type="button"
                      data-form-builder-target="paletteItem"
                      data-search-text="Email E-mail"
                      data-action="click->form-builder#addFromPalette"
                      data-field-type="email"
                      data-field-label="Digite seu melhor E-mail"
                      data-field-required="true"
                      data-field-placeholder="nome@email.com"
                      class="rounded-xl border border-slate-200 p-3 hover:bg-slate-50 text-left transition">
                <p class="text-sm font-semibold text-slate-900">E-mail</p>
                <p class="text-xs text-slate-500 mt-1">Contato</p>
              </button>
              <button type="button"
                      data-form-builder-target="paletteItem"
                      data-search-text="Telefone Número"
                      data-action="click->form-builder#addFromPalette"
                      data-field-type="phone"
                      data-field-label="Digite um Telefone válido"
                      data-field-required="true"
                      data-field-placeholder="(00) 00000-0000"
                      class="rounded-xl border border-slate-200 p-3 hover:bg-slate-50 text-left transition">
                <p class="text-sm font-semibold text-slate-900">Telefone</p>
                <p class="text-xs text-slate-500 mt-1">Contato</p>
              </button>
            </div>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-3">Escolhas</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <button type="button"
                      data-form-builder-target="paletteItem"
                      data-search-text="Lista suspensa Seleção"
                      data-action="click->form-builder#addFromPalette"
                      data-field-type="select"
                      data-field-label="Escolha uma opção"
                      data-field-placeholder=""
                      data-field-options="Opção 1\nOpção 2\nOpção 3"
                      class="rounded-xl border border-slate-200 p-3 hover:bg-slate-50 text-left transition">
                <p class="text-sm font-semibold text-slate-900">Lista suspensa</p>
                <p class="text-xs text-slate-500 mt-1">Seleção</p>
              </button>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-3">Texto</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <button type="button"
                      data-form-builder-target="paletteItem"
                      data-search-text="Texto curto"
                      data-action="click->form-builder#addFromPalette"
                      data-field-type="text"
                      data-field-label="Digite sua resposta"
                      data-field-placeholder="Digite sua resposta aqui..."
                      class="rounded-xl border border-slate-200 p-3 hover:bg-slate-50 text-left transition">
                <p class="text-sm font-semibold text-slate-900">Texto curto</p>
                <p class="text-xs text-slate-500 mt-1">Texto</p>
              </button>
              <button type="button"
                      data-form-builder-target="paletteItem"
                      data-search-text="Texto longo"
                      data-action="click->form-builder#addFromPalette"
                      data-field-type="textarea"
                      data-field-label="Conte mais sobre você"
                      data-field-placeholder="Digite sua resposta aqui..."
                      class="rounded-xl border border-slate-200 p-3 hover:bg-slate-50 text-left transition">
                <p class="text-sm font-semibold text-slate-900">Texto longo</p>
                <p class="text-xs text-slate-500 mt-1">Texto</p>
              </button>
            </div>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-3">Outros</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <button type="button"
                      data-form-builder-target="paletteItem"
                      data-search-text="Aviso Informação"
                      data-action="click->form-builder#addFromPalette"
                      data-field-type="text"
                      data-field-label="Informação"
                      data-field-placeholder="Escreva um texto..."
                      class="rounded-xl border border-slate-200 p-3 hover:bg-slate-50 text-left transition">
                <p class="text-sm font-semibold text-slate-900">Aviso</p>
                <p class="text-xs text-slate-500 mt-1">Bloco informativo</p>
              </button>
            </div>
          </div>
        </div>

        <div class="text-xs text-slate-500">
          Integrações e Google Drive foram intencionalmente omitidos.
        </div>
      </div>
    </div>
    </div>
  </div>
<% end %>

