<div class="max-w-6xl mx-auto px-4 py-8">
  <div class="flex items-start justify-between gap-4 mb-6">
    <div class="min-w-0">
      <div class="flex items-center gap-3">
        <span class="inline-flex w-3 h-3 rounded-full mt-1" style="background:<%= @form.accent_color %>"></span>
        <div class="min-w-0">
          <h1 class="text-2xl font-bold text-white truncate"><%= @form.name %></h1>
          <p class="text-sm text-slate-400 mt-1"><%= @form.description.presence || "—" %></p>
        </div>
      </div>
      <div class="mt-3 flex flex-wrap gap-2 text-xs">
        <span class="bg-slate-800 text-slate-200 px-2 py-1 rounded-lg">Slug: <code><%= @form.slug %></code></span>
        <span class="bg-slate-800 text-slate-200 px-2 py-1 rounded-lg">Segmento alvo: <%= @form.target_segment&.name || "—" %></span>
        <span class="bg-slate-800 text-slate-200 px-2 py-1 rounded-lg">Respostas: <%= @form.form_responses.count %></span>
      </div>
    </div>

    <div class="flex flex-wrap gap-2">
      <%= link_to "Voltar", forms_path, class: "text-xs bg-slate-800 hover:bg-slate-700 text-slate-200 px-3 py-1.5 rounded-lg transition" %>
      <%= link_to "Editar", edit_form_path(@form), class: "text-xs bg-cyan-500/15 hover:bg-cyan-500/25 text-cyan-200 px-3 py-1.5 rounded-lg transition" %>
      <%= link_to "Link público", public_form_path(@form.slug), target: "_blank", class: "text-xs bg-indigo-500/15 hover:bg-indigo-500/25 text-indigo-200 px-3 py-1.5 rounded-lg transition" %>
      <%= button_to "Remover", form_path(@form), method: :delete, data: { turbo_confirm: "Remover #{@form.name}?" }, class: "text-xs bg-rose-500/10 hover:bg-rose-500/20 text-rose-200 px-3 py-1.5 rounded-lg transition" %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-1 space-y-4">
      <div class="bg-slate-900/70 border border-white/10 rounded-2xl p-5 backdrop-blur-xl">
        <h2 class="font-semibold text-white text-sm uppercase tracking-wider mb-3">Campos</h2>
        <div class="space-y-2">
          <% @form.form_fields.each do |field| %>
            <div class="flex items-center justify-between text-sm">
              <span class="text-slate-200"><%= field.label %></span>
              <span class="text-xs text-slate-500"><%= field.field_type %><%= " · obrigatório" if field.required? %></span>
            </div>
          <% end %>
        </div>
      </div>
      <div class="bg-indigo-500/10 border border-indigo-500/20 rounded-2xl p-5 text-xs text-indigo-200">
        <p><strong>Operação rápida:</strong> para testar o formulário, abra o link público e envie uma resposta com e-mail.</p>
      </div>
    </div>

    <div class="lg:col-span-2">
      <div class="bg-slate-900/70 border border-white/10 rounded-2xl overflow-hidden backdrop-blur-xl">
        <div class="px-5 py-4 border-b border-white/10 flex items-center justify-between">
          <h2 class="font-semibold text-white text-sm uppercase tracking-wider">Últimas respostas</h2>
          <span class="text-xs text-slate-500">Mostrando até 100</span>
        </div>
        <% if @responses.empty? %>
          <div class="px-5 py-10 text-center">
            <p class="text-slate-400 text-sm">Nenhuma resposta ainda.</p>
          </div>
        <% else %>
          <div class="divide-y divide-white/10">
            <% @responses.each do |r| %>
              <div class="px-5 py-4 text-sm flex items-center justify-between gap-3">
                <div class="min-w-0">
                  <p class="text-white truncate"><%= r.email.presence || r.contact&.email || "—" %></p>
                  <p class="text-xs text-slate-500 mt-0.5"><%= l(r.submitted_at, format: :short) %> · IP: <%= r.ip %></p>
                </div>
                <div class="text-right">
                  <p class="text-xs text-slate-400">Contato: <span class="text-slate-200"><%= r.contact&.full_name || "—" %></span></p>
                  <p class="text-xs text-slate-400">Segmento: <span class="text-slate-200"><%= r.segment&.name || "—" %></span></p>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

