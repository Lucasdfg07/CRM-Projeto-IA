<%= form_with model: campaign, class: "space-y-0", data: { controller: "email-editor" } do |f| %>
  <%= render "shared/errors", object: campaign %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Left: Settings -->
    <div class="space-y-5">
      <div class="bg-slate-800 border border-slate-700 rounded-xl p-5 space-y-4">
        <h2 class="font-semibold text-white text-sm uppercase tracking-wider">Configurações</h2>

        <div>
          <%= f.label :name, "Nome da campanha", class: "block text-xs font-medium text-slate-400 mb-1" %>
          <%= f.text_field :name, placeholder: "Ex: Black Friday 2026", class: "w-full bg-slate-900 border border-slate-600 rounded-lg px-3 py-2 text-white text-sm placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>

        <div>
          <%= f.label :subject, "Assunto do email", class: "block text-xs font-medium text-slate-400 mb-1" %>
          <%= f.text_field :subject, placeholder: "Ex: Oferta especial para você!", class: "w-full bg-slate-900 border border-slate-600 rounded-lg px-3 py-2 text-white text-sm placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>

        <div>
          <%= f.label :preview_text, "Texto de prévia", class: "block text-xs font-medium text-slate-400 mb-1" %>
          <%= f.text_field :preview_text, placeholder: "Aparece no preview do cliente de email...", class: "w-full bg-slate-900 border border-slate-600 rounded-lg px-3 py-2 text-white text-sm placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>

        <div>
          <%= f.label :email_provider_id, "Provedor de envio", class: "block text-xs font-medium text-slate-400 mb-1" %>
          <%= f.select :email_provider_id,
                providers.map { |p| ["#{p.name} (#{p.username})", p.id] },
                { include_blank: "Selecione um provedor..." },
                class: "w-full bg-slate-900 border border-slate-600 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>

        <div>
          <%= f.label :reply_to, "Responder para (opcional)", class: "block text-xs font-medium text-slate-400 mb-1" %>
          <%= f.email_field :reply_to, placeholder: "reply@suaempresa.com", class: "w-full bg-slate-900 border border-slate-600 rounded-lg px-3 py-2 text-white text-sm placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
      </div>

      <div class="bg-slate-800 border border-slate-700 rounded-xl p-5 space-y-3">
        <h2 class="font-semibold text-white text-sm uppercase tracking-wider">Destinatários (filtro)</h2>
        <p class="text-xs text-slate-500">Aplica-se aos contatos dos segmentos selecionados. O envio é sempre por e-mail.</p>
        <%= f.label :recipient_filter, "Quem incluir", class: "block text-xs font-medium text-slate-400 mb-1" %>
        <%= f.select :recipient_filter,
              Campaign::RECIPIENT_FILTERS.map { |k| [recipient_filter_label(k), k] },
              {},
              class: "w-full bg-slate-900 border border-slate-600 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>

      <!-- Segments -->
      <div class="bg-slate-800 border border-slate-700 rounded-xl p-5 space-y-3">
        <h2 class="font-semibold text-white text-sm uppercase tracking-wider">Segmentos alvo</h2>
        <% if segments.empty? %>
          <p class="text-xs text-slate-500">Nenhum segmento. <%= link_to "Criar segmento", new_segment_path, class: "text-indigo-400 hover:underline", target: "_blank" %></p>
        <% else %>
          <div class="space-y-1.5 max-h-52 overflow-y-auto pr-1">
            <% segments.each do |segment| %>
              <label class="flex items-center gap-2.5 cursor-pointer hover:bg-slate-700 rounded-lg px-2 py-1.5 transition">
                <input type="checkbox"
                       name="campaign[segment_ids][]"
                       value="<%= segment.id %>"
                       <%= "checked" if campaign.segment_ids.include?(segment.id) %>
                       class="accent-indigo-500 w-4 h-4 rounded flex-shrink-0">
                <div class="w-2.5 h-2.5 rounded-full flex-shrink-0" style="background: <%= segment.color %>"></div>
                <span class="text-sm text-slate-300 flex-1 truncate"><%= segment.name %></span>
                <span class="text-xs text-slate-500"><%= segment.contacts_count %></span>
              </label>
            <% end %>
          </div>
        <% end %>
      </div>

      <!-- Actions -->
      <div class="flex flex-col gap-2">
        <%= f.submit "Salvar rascunho", class: "w-full bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium py-2.5 rounded-lg cursor-pointer transition" %>
        <%= link_to "Cancelar", campaigns_path, class: "block w-full text-center bg-slate-700 hover:bg-slate-600 text-slate-300 text-sm py-2.5 rounded-lg transition" %>
      </div>
    </div>

    <!-- Center + Right: Email Editor -->
    <div class="lg:col-span-2 space-y-4">
      <!-- Toolbar -->
      <div class="bg-slate-800 border border-slate-700 rounded-xl p-3 flex flex-wrap gap-2 items-center">
        <span class="text-xs font-medium text-slate-400 uppercase tracking-wider mr-1">Adicionar bloco:</span>
        <% blocks = [
          ["Cabeçalho", "header", "M4 6h16M4 10h16M4 14h8"],
          ["Texto", "text", "M4 6h16M4 10h16M4 14h16M4 18h10"],
          ["Botão CTA", "button", "M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5"],
          ["Imagem", "image", "M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"],
          ["Divisor", "divider", "M20 12H4"],
          ["Rodapé", "footer", "M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"]
        ] %>
        <% blocks.each do |label, type, icon| %>
          <button type="button"
                  data-action="click->email-editor#addBlock"
                  data-block-type="<%= type %>"
                  class="flex items-center gap-1.5 text-xs bg-slate-700 hover:bg-indigo-600 text-slate-300 hover:text-white px-3 py-1.5 rounded-lg transition">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= icon %>"/></svg>
            <%= label %>
          </button>
        <% end %>
        <div class="ml-auto flex gap-2">
          <button type="button" data-action="click->email-editor#preview" class="text-xs bg-emerald-600/20 hover:bg-emerald-600/40 text-emerald-400 px-3 py-1.5 rounded-lg transition">
            Prévia
          </button>
          <button type="button" data-action="click->email-editor#clearAll" class="text-xs text-slate-500 hover:text-red-400 px-2 py-1.5 rounded-lg transition">
            Limpar tudo
          </button>
        </div>
      </div>

      <!-- Personalization tip -->
      <div class="bg-indigo-600/10 border border-indigo-600/20 rounded-lg px-4 py-2 text-xs text-indigo-300">
        <strong>Personalização:</strong> Use <code class="bg-indigo-600/20 px-1 rounded">{{nome}}</code>, <code class="bg-indigo-600/20 px-1 rounded">{{nome_completo}}</code> e <code class="bg-indigo-600/20 px-1 rounded">{{email}}</code> para personalizar o email de cada destinatário.
      </div>

      <!-- Canvas -->
      <div class="bg-white rounded-xl overflow-hidden shadow-2xl min-h-96 relative"
           data-email-editor-target="canvas"
           data-action="dragover->email-editor#onDragOver drop->email-editor#onDrop">
        <!-- Blocks render here -->
        <div data-email-editor-target="blocks" id="email-blocks">
          <!-- Placeholder when empty -->
          <div data-email-editor-target="placeholder" class="flex items-center justify-center h-64 text-slate-400 text-sm p-8 text-center">
            <div>
              <svg class="w-10 h-10 mx-auto mb-3 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <p>Clique em um bloco acima para começar a montar seu email</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Hidden field for HTML body -->
      <%= f.hidden_field :html_body, data: { email_editor_target: "output" } %>
    </div>
  </div>
<% end %>
