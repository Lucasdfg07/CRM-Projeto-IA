<div class="max-w-6xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-white">Campanhas de Email</h1>
      <p class="text-slate-400 text-sm mt-1">Crie e envie campanhas para seus segmentos</p>
    </div>
    <%= link_to new_campaign_path, class: "flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium px-4 py-2 rounded-lg transition" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Nova Campanha
    <% end %>
  </div>

  <% if @campaigns.empty? %>
    <div class="text-center py-20 bg-slate-800/50 rounded-2xl border border-slate-700">
      <svg class="w-14 h-14 mx-auto text-slate-500 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      <p class="text-slate-400">Nenhuma campanha criada ainda.</p>
      <%= link_to "Criar primeira campanha", new_campaign_path, class: "mt-3 inline-block text-indigo-400 hover:text-indigo-300 text-sm" %>
    </div>
  <% else %>
    <div class="space-y-3">
      <% @campaigns.each do |campaign| %>
        <% status_colors = { "draft" => "bg-slate-600 text-slate-300", "sending" => "bg-amber-500/20 text-amber-400", "sent" => "bg-emerald-500/20 text-emerald-400", "cancelled" => "bg-red-500/20 text-red-400", "scheduled" => "bg-blue-500/20 text-blue-400" } %>
        <% status_labels = { "draft" => "Rascunho", "sending" => "Enviando...", "sent" => "Enviado", "cancelled" => "Cancelado", "scheduled" => "Agendado" } %>
        <div class="bg-slate-800 border border-slate-700 rounded-xl px-5 py-4 flex items-center gap-4">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 flex-wrap">
              <span class="font-semibold text-white truncate"><%= campaign.name %></span>
              <span class="text-xs px-2 py-0.5 rounded-full <%= status_colors[campaign.status] %>"><%= status_labels[campaign.status] %></span>
            </div>
            <p class="text-sm text-slate-400 truncate mt-0.5"><%= campaign.subject %></p>
            <div class="flex items-center gap-3 mt-1.5 flex-wrap">
              <span class="text-xs text-slate-500"><%= campaign.segments.map(&:name).join(", ").presence || "Sem segmento" %></span>
              <% if campaign.sent? %>
                <span class="text-xs text-slate-500"><%= campaign.total_recipients %> destinatários · <%= campaign.delivery_rate %>% entregues</span>
              <% end %>
              <span class="text-xs text-slate-600"><%= l(campaign.created_at, format: :short) %></span>
            </div>
          </div>
          <div class="flex items-center gap-2 flex-shrink-0">
            <% if campaign.draft? || campaign.scheduled? %>
              <%= button_to send_campaign_campaign_path(campaign), method: :post, data: { turbo_confirm: "Enviar campanha \"#{campaign.name}\" agora?" }, class: "text-xs bg-emerald-600 hover:bg-emerald-500 text-white px-3 py-1.5 rounded-lg transition" do %>
                Enviar
              <% end %>
            <% end %>
            <%= link_to preview_campaign_path(campaign), target: "_blank", class: "text-xs text-slate-400 hover:text-white bg-slate-700 hover:bg-slate-600 px-3 py-1.5 rounded-lg transition" do %>Prévia<% end %>
            <%= link_to edit_campaign_path(campaign), class: "text-xs text-indigo-400 bg-indigo-600/10 hover:bg-indigo-600/20 px-3 py-1.5 rounded-lg transition" do %>Editar<% end %>
            <%= button_to duplicate_campaign_path(campaign), method: :post, class: "text-xs text-slate-400 bg-slate-700 hover:bg-slate-600 px-3 py-1.5 rounded-lg transition" do %>Duplicar<% end %>
            <%= button_to campaign_path(campaign), method: :delete, data: { turbo_confirm: "Remover #{campaign.name}?" }, class: "text-xs text-red-400 bg-red-500/10 hover:bg-red-500/20 px-3 py-1.5 rounded-lg transition" do %>Remover<% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
