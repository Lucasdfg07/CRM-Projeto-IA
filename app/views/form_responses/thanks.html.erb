<div class="min-h-screen bg-black text-white">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute -top-40 left-1/2 -translate-x-1/2 w-[900px] h-[900px] rounded-full blur-3xl opacity-20"
         style="background: radial-gradient(circle at center, <%= @form.accent_color %>, transparent 60%);"></div>
  </div>

  <div class="relative max-w-2xl mx-auto px-6 py-24 text-center">
    <div class="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-full px-4 py-1 text-xs text-slate-300">
      <span class="w-2 h-2 rounded-full" style="background:<%= @form.accent_color %>"></span>
      AIOX Forms
    </div>

    <h1 class="mt-6 text-4xl font-semibold tracking-tight">Resposta enviada</h1>
    <p class="mt-3 text-slate-400 text-lg">Obrigado por responder. Você pode fechar esta página.</p>

    <div class="mt-10 flex items-center justify-center gap-3">
      <%= link_to "Voltar ao início", public_form_path(@form.slug),
            class: "inline-flex items-center justify-center px-6 py-3 rounded-md text-sm font-semibold text-black",
            style: "background: #{@form.accent_color}" %>
    </div>
  </div>
</div>

