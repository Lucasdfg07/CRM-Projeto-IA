<div class="min-h-screen bg-black text-white" data-controller="public-form-flow">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute -top-40 left-1/2 -translate-x-1/2 w-[900px] h-[900px] rounded-full blur-3xl opacity-20"
         style="background: radial-gradient(circle at center, <%= @form.accent_color %>, transparent 60%);"></div>
  </div>

  <!-- top progress -->
  <div class="fixed top-0 left-0 right-0 z-20">
    <div class="h-1 bg-white/5">
      <div class="h-1" data-public-form-flow-target="progress" style="width:0%; background:<%= @form.accent_color %>"></div>
    </div>
  </div>

  <div class="relative max-w-3xl mx-auto px-6 py-20">
    <div class="flex items-center justify-between text-xs text-slate-500 mb-10">
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full" style="background:<%= @form.accent_color %>"></span>
        <span>AIOX Forms</span>
      </div>
      <div data-public-form-flow-target="progressText">1/<%= @fields.size %></div>
    </div>

    <% if flash[:alert].present? %>
      <div class="mb-6 bg-rose-500/10 border border-rose-500/25 text-rose-200 text-sm rounded-xl px-4 py-3">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <%= form_with url: public_form_path(@form.slug), method: :post, class: "space-y-8" do %>
      <% @fields.each_with_index do |field, idx| %>
        <div class="hidden" data-public-form-flow-target="step">
          <div class="text-slate-500 text-xs mb-4">
            <%= idx + 1 %> →
          </div>

          <h2 class="text-3xl md:text-4xl font-semibold tracking-tight">
            <%= field.label %>
            <% if field.required? %><span class="text-rose-300">*</span><% end %>
          </h2>

          <div class="mt-8">
            <% base = "w-full bg-transparent border-0 border-b border-white/20 px-0 py-3 text-2xl text-white placeholder-slate-600 focus:outline-none focus:ring-0" %>
            <% placeholder = field.placeholder.presence || "Digite sua resposta aqui..." %>

            <% case field.field_type %>
            <% when "textarea" %>
              <textarea name="answers[<%= field.id %>]" rows="4" class="<%= base %>" placeholder="<%= placeholder %>" <%= "required" if field.required? %>></textarea>
              <p class="text-xs text-slate-500 mt-3">Dica: use <span class="text-slate-300">Shift + Enter</span> para quebrar linha.</p>
            <% when "select" %>
              <select name="answers[<%= field.id %>]" class="w-full bg-transparent border border-white/15 rounded-xl px-4 py-3 text-lg text-white focus:outline-none focus:ring-2" style="--tw-ring-color:<%= @form.accent_color %>" <%= "required" if field.required? %>>
                <option value="">Selecione…</option>
                <% field.options_list.each do |opt| %>
                  <option value="<%= opt %>"><%= opt %></option>
                <% end %>
              </select>
            <% when "email" %>
              <input type="email" name="answers[<%= field.id %>]" class="<%= base %>" placeholder="<%= field.placeholder.presence || "nome@email.com" %>" <%= "required" if field.required? %>>
            <% when "phone" %>
              <input type="tel" name="answers[<%= field.id %>]" class="<%= base %>" placeholder="<%= field.placeholder.presence || "(00) 00000-0000" %>" <%= "required" if field.required? %>>
            <% else %>
              <input type="text" name="answers[<%= field.id %>]" class="<%= base %>" placeholder="<%= placeholder %>" <%= "required" if field.required? %>>
            <% end %>
          </div>

          <div class="mt-10 flex items-center gap-3">
            <button type="button"
                    data-public-form-flow-target="okButton"
                    data-action="click->public-form-flow#next"
                    class="inline-flex items-center justify-center px-6 py-3 rounded-md text-sm font-semibold text-black"
                    style="background:<%= @form.accent_color %>">
              OK
            </button>
            <span class="text-xs text-slate-500">pressione Enter ↵</span>
          </div>
        </div>
      <% end %>

      <button type="submit"
              data-public-form-flow-target="submitButton"
              class="hidden inline-flex items-center justify-center px-6 py-3 rounded-md text-sm font-semibold text-black"
              style="background:<%= @form.accent_color %>">
        Enviar
      </button>
    <% end %>

    <div class="fixed right-6 bottom-6 flex flex-col gap-2">
      <button type="button" data-action="click->public-form-flow#prev" class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 text-slate-200 hover:bg-white/10 transition">↑</button>
      <button type="button" data-action="click->public-form-flow#next" class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 text-slate-200 hover:bg-white/10 transition">↓</button>
    </div>
  </div>
</div>

