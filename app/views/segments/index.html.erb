<div class="max-w-5xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-white">Segmentos</h1>
      <p class="text-slate-400 text-sm mt-1">Agrupe contatos para campanhas direcionadas</p>
    </div>
    <%= link_to new_segment_path, class: "flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium px-4 py-2 rounded-lg transition" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Novo Segmento
    <% end %>
  </div>

  <% if @segments.empty? %>
    <div class="text-center py-20 bg-slate-800/50 rounded-2xl border border-slate-700">
      <svg class="w-12 h-12 mx-auto text-slate-500 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      <p class="text-slate-400">Nenhum segmento criado ainda.</p>
    </div>
  <% else %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @segments.each do |segment| %>
        <div class="bg-slate-800 border border-slate-700 rounded-xl p-5 flex flex-col gap-3">
          <div class="flex items-start justify-between">
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 rounded-full flex-shrink-0" style="background: <%= segment.color %>"></div>
              <span class="font-semibold text-white"><%= segment.name %></span>
            </div>
            <div class="flex gap-1">
              <%= link_to edit_segment_path(segment), class: "p-1.5 text-slate-400 hover:text-indigo-400 rounded transition" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
              <% end %>
              <%= button_to segment_path(segment), method: :delete, data: { turbo_confirm: "Remover segmento #{segment.name}?" }, class: "p-1.5 text-slate-400 hover:text-red-400 rounded transition" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              <% end %>
            </div>
          </div>
          <% if segment.description.present? %>
            <p class="text-sm text-slate-400 line-clamp-2"><%= segment.description %></p>
          <% end %>
          <div class="flex items-center justify-between mt-auto pt-2 border-t border-slate-700">
            <span class="text-sm text-slate-400"><%= segment.contacts_count %> contato(s)</span>
            <%= link_to "Gerenciar", segment_path(segment), class: "text-xs text-indigo-400 hover:text-indigo-300 transition" %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
