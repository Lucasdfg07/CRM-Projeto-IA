<%= form_with model: @company, class: "space-y-4" do |f| %>
  <%= render "shared/errors", record: @company %>
  <div class="grid gap-4 md:grid-cols-2">
    <div class="md:col-span-2">
      <%= f.label :name, class: "crm-label" %>
      <%= f.text_field :name, class: "crm-input" %>
    </div>
    <div>
      <%= f.label :sector, class: "crm-label" %>
      <%= f.text_field :sector, class: "crm-input" %>
    </div>
    <div>
      <%= f.label :website, class: "crm-label" %>
      <%= f.text_field :website, class: "crm-input", placeholder: "https://" %>
    </div>
    <div class="md:col-span-2">
      <%= f.label :notes, class: "crm-label" %>
      <%= f.text_area :notes, rows: 4, class: "crm-input" %>
    </div>
  </div>
  <div class="flex flex-wrap gap-3">
    <%= f.submit class: "crm-btn-primary" %>
    <%= link_to "Cancelar", companies_path, class: "crm-btn-ghost" %>
  </div>
<% end %>
